# Arrow R package configuration
# These settings prevent conflicts with GDAL/system Arrow installations
ARROW_USE_PKG_CONFIG=FALSE
NOT_CRAN=TRUE
LIBARROW_BINARY=FALSE
LIBARROW_MINIMAL=FALSE

# Force Arrow to build its own C++ libraries (no system dependencies)
ARROW_R_DEV=TRUE
CMAKE_ARGS=-DArrow_SOURCE=BUNDLED

# Additional compilation flags for isolation
ARROW_R_CXXFLAGS=-DARROW_STATIC=ON